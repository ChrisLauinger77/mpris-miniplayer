msgid "MPRIS MiniPlayer"
msgstr "MPRIS MiniPlayer"

msgid "Control MPRIS-compatible media players"
msgstr "Controlar reproductores multimedia compatibles con MPRIS"

msgid "MPRIS MiniPlayer is a small GTK mini player for Linux media players that expose the MPRIS interface on the session bus."
msgstr "MPRIS MiniPlayer es un pequeño minirreproductor GTK para reproductores multimedia de Linux que exponen la interfaz MPRIS en el bus de sesión."

msgid "Initial development release."
msgstr "Versión inicial de desarrollo."

msgid "Christian Lauinger"
msgstr "Christian Lauinger"

msgid "No player running"
msgstr "No hay ningún reproductor en ejecución"

msgid "Start an MPRIS-compatible media player"
msgstr "Inicia un reproductor multimedia compatible con MPRIS"

msgid "Previous"
msgstr "Anterior"

msgid "Play or pause"
msgstr "Reproducir o pausar"

msgid "Next"
msgstr "Siguiente"

msgid "Choose player"
msgstr "Elegir reproductor"

msgid "No player detected"
msgstr "No se detectó ningún reproductor"

msgid "Start any MPRIS-compatible player"
msgstr "Inicia cualquier reproductor compatible con MPRIS"

msgid "Player unavailable"
msgstr "Reproductor no disponible"

msgid "Unknown track"
msgstr "Pista desconocida"

msgid "Unknown artist"
msgstr "Artista desconocido"
