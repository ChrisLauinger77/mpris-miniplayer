msgid "MPRIS MiniPlayer"
msgstr "MPRIS MiniPlayer"

msgid "Control MPRIS-compatible media players"
msgstr "MPRIS-kompatible Medienplayer steuern"

msgid "MPRIS MiniPlayer is a small GTK mini player for Linux media players that expose the MPRIS interface on the session bus."
msgstr "MPRIS MiniPlayer ist ein kleiner GTK-Mini-Player für Linux-Medienplayer, die die MPRIS-Schnittstelle auf dem Sitzungsbus bereitstellen."

msgid "Initial development release."
msgstr "Erste Entwicklungsversion."

msgid "Christian Lauinger"
msgstr "Christian Lauinger"

msgid "No player running"
msgstr "Kein Player läuft"

msgid "Start an MPRIS-compatible media player"
msgstr "Starte einen MPRIS-kompatiblen Medienplayer"

msgid "Previous"
msgstr "Zurück"

msgid "Play or pause"
msgstr "Wiedergabe oder Pause"

msgid "Next"
msgstr "Weiter"

msgid "Choose player"
msgstr "Player auswählen"

msgid "No player detected"
msgstr "Kein Player erkannt"

msgid "Start any MPRIS-compatible player"
msgstr "Starte einen MPRIS-kompatiblen Player"

msgid "Player unavailable"
msgstr "Player nicht verfügbar"

msgid "Unknown track"
msgstr "Unbekannter Titel"

msgid "Unknown artist"
msgstr "Unbekannter Künstler"
