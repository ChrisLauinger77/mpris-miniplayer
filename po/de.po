msgid "MPRIS MiniPlayer"
msgstr "MPRIS MiniPlayer"

#: data/io.github.ChrisLauinger.MprisMiniPlayer.desktop.in:3
#: data/io.github.ChrisLauinger.MprisMiniPlayer.metainfo.xml.in:7
msgid "Control MPRIS-compatible media players"
msgstr "MPRIS-kompatible Medienspieler steuern"

#: data/io.github.ChrisLauinger.MprisMiniPlayer.metainfo.xml.in:9
msgid ""
"MPRIS MiniPlayer is a small GTK mini player for Linux media players that "
"expose the MPRIS interface on the session bus."
msgstr ""
"MPRIS MiniPlayer ist ein kleiner GTK-Mini-Player für Linux-Medienspieler, "
"die die MPRIS-Schnittstelle auf dem Sitzungsbus bereitstellen."

#: data/io.github.ChrisLauinger.MprisMiniPlayer.metainfo.xml.in:16
msgid "Christian Lauinger"
msgstr "Christian Lauinger"

#: src/background-portal.vala:38 src/background-portal.vala:143
msgid "Monitoring media players"
msgstr "Medienspieler überwachen"

#: src/background-portal.vala:77
msgid "Keep watching for MPRIS-compatible media players"
msgstr "Weiter nach MPRIS-kompatiblen Medienspielern suchen"

#: src/status-indicator.vala:297
msgid "Hide"
msgstr "Ausblenden"

#: src/status-indicator.vala:297
msgid "Show"
msgstr "Anzeigen"

#: src/status-indicator.vala:299 src/window.vala:105
msgid "Compact Mode"
msgstr "Kompakter Modus"

#: src/status-indicator.vala:301 src/preferences-window.vala:14
