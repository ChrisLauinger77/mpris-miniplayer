<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.ChrisLauinger.MprisMiniPlayer</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>MPRIS MiniPlayer</name>
  <summary>Control MPRIS-compatible media players</summary>
  <description>
    <p>
      MPRIS MiniPlayer is a small GTK mini player for Linux media players that expose the MPRIS interface on the session bus.
    </p>
  </description>
  <launchable type="desktop-id">io.github.ChrisLauinger.MprisMiniPlayer.desktop</launchable>
  <url type="homepage">https://github.com/ChrisLauinger77/mpris-miniplayer</url>
  <developer id="io.github.chrislauinger77">
    <name>Christian Lauinger</name>
  </developer>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="0.2.0" date="2026-06-21">
      <description>
        <p>Add background operation, automatic window visibility, preferences, and start-on-login support.</p>
      </description>
    </release>
    <release version="0.1.0" date="2026-06-20">
      <description>
        <p>Initial development release.</p>
      </description>
    </release>
  </releases>
</component>
